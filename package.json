{
  "name": "translater.js",
  "version": "1.0.12",
  "description": "Simple translation tools.",
  "main": "dist/translater.min.js",
  "homepage": "http://jaywcjlove.github.io/translater.js/",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:min": "rollup -c rollup.config.mjs --environment MINIFY:true",
    "build:dist": "rollup -c rollup.config.mjs",
    "build": "npm run build:dist && npm run build:min",
    "watch": "rollup -c rollup.config.mjs -w",
    "watch:min": "rollup -c rollup.config.mjs --environment MINIFY:true -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaywcjlove/translater.js.git"
  },
  "author": "kenny wong <wowohoo@qq.com>",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.41.1"
  }
}
